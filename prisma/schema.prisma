generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// NextAuth Required Models
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Core Models
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?   @unique
  password      String?
  role          String    @default("CLIENT") // CLIENT, EXPERT, ADMIN
  specialty       String?   // ENGINEER, LAWYER (for EXPERT role)
  bio             String?
  experienceYears Int?      // years of experience (experts)
  nationalIdImage    String?   // uploaded national ID image path (experts)
  profileImage       String?   // expert profile photo URL
  syndicateCardImage String?   // syndicate card image (كارت نقابة)
  serviceRate        Float?    // expert service rate
  verified        Boolean   @default(false) // admin approval for experts
  active          Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  requests           InspectionRequest[]     @relation("ClientRequests")
  assignedRequests   InspectionRequest[]     @relation("ProviderRequests")
  reports            Report[]
  ratingsGiven       Rating[]                @relation("RaterRatings")
  ratingsReceived    Rating[]                @relation("RatedRatings")
  notifications      Notification[]
  continuationRequests ContinuationRequest[]
  expertTerms          ExpertTerm[]          @relation("ExpertTerms")
  requestTermsAsExpert RequestTerm[]         @relation("RequestTermExpert")
}

model Property {
  id        String              @id @default(cuid())
  location  String
  area      String?
  type      String?             // Apartment, Villa, Office, Land
  notes     String?
  requests  InspectionRequest[]
}

model InspectionRequest {
  id              String    @id @default(cuid())
  userId          String
  propertyId      String
  providerId      String?   // assigned provider
  packageName     String    // LEGAL, TECHNICAL, FULL
  packagePrice    Float
  serviceType     String    @default("INSPECTION") // INSPECTION
  paymentMethod   String    @default("ONLINE") // ONLINE, CASH
  paymentStatus   String    @default("PENDING") // PENDING, PAID, FAILED, CASH
  status          String    @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  scheduledDate   DateTime?
  notes           String?   // user notes
  adminNotes      String?   // admin internal notes
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User          @relation("ClientRequests", fields: [userId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])
  provider     User?         @relation("ProviderRequests", fields: [providerId], references: [id])
  reports       Report[]
  transactions  Transaction[]
  ratings       Rating[]
  continuations ContinuationRequest[]
  requestTerms  RequestTerm[]
}

model Transaction {
  id             String            @id @default(cuid())
  requestId      String
  amount         Float
  currency       String            @default("EGP")
  paymentMethod  String            // CARD, WALLET, FAWRY, VODAFONE_CASH, CASH
  status         String            @default("PENDING") // PENDING, SUCCESS, FAILED
  gatewayTransId String?
  createdAt      DateTime          @default(now())

  request InspectionRequest @relation(fields: [requestId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  requestId   String
  authorId    String
  type        String   // LEGAL, TECHNICAL
  title       String
  summary     String?  @db.Text
  content     String?  @db.Text // detailed findings JSON or markdown
  pdfUrl      String?
  status      String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  request InspectionRequest @relation(fields: [requestId], references: [id])
  author  User              @relation(fields: [authorId], references: [id])
}

model Rating {
  id         String   @id @default(cuid())
  requestId  String
  raterId    String   // the user giving the rating
  ratedId    String   // the provider being rated
  score      Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  request InspectionRequest @relation(fields: [requestId], references: [id])
  rater   User              @relation("RaterRatings", fields: [raterId], references: [id])
  rated   User              @relation("RatedRatings", fields: [ratedId], references: [id])

  @@unique([requestId, raterId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, REQUEST_UPDATE, ASSIGNMENT, REPORT, PAYMENT
  read      Boolean  @default(false)
  link      String?  // optional link to navigate to
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ContinuationRequest {
  id        String   @id @default(cuid())
  requestId String
  details   String   @db.Text
  caseType  String
  lawyerId  String?  // client-preferred lawyer
  cost      Float?
  status    String   @default("PENDING") // PENDING, PRICED, ACCEPTED, IN_PROGRESS, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request InspectionRequest @relation(fields: [requestId], references: [id])
  lawyer  User?             @relation(fields: [lawyerId], references: [id])
}

model ExpertTerm {
  id              String   @id @default(cuid())
  expertId        String
  termKey         String
  experienceYears Int
  price           Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expert User @relation("ExpertTerms", fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([expertId, termKey])
}

model RequestTerm {
  id          String    @id @default(cuid())
  requestId   String
  termKey     String
  expertId    String
  price       Float
  status      String    @default("PENDING") // PENDING, ARRIVED, IN_PROGRESS, COMPLETED
  arrivedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  request InspectionRequest @relation(fields: [requestId], references: [id])
  expert  User              @relation("RequestTermExpert", fields: [expertId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  phone     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
